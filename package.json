  "license": "GPL-3.0",
  "scripts": {
    "clean:coverage": "rimraf coverage",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "stylelint": "stylelint --config .stylelint.config.cjs 'src/**/*.{vue,scss}'",
    "stylelint:fix": "stylelint --config .stylelint.config.cjs --fix 'src/**/*.{vue,scss}'",
    "linter": "eslint -c .eslint.config.mjs --ext .js,.vue,.ts, src",
    "linter:fix": "eslint -c .eslint.config.mjs --fix --ext .js,.vue,.ts, src",
    "lint": "pnpm run linter && pnpm run stylelint",
    "lint:fix": "pnpm run linter:fix && pnpm run stylelint:fix",
    "test": "pnpm run clean:coverage && jest",
    "test:watch": "pnpm run clean:coverage && jest --watch"
  },
  "dependencies": {
    "@v1nt1248/3nclient-lib": "0.3.19",
    "pinia": "3.0.4",
    "punycode": "2.3.1",
    "vue": "3.5.32",
    "vue-i18n": "11.3.2",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/vue": "8.1.0",
    "@types/jasmine": "6.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/devtools": "8.1.1",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vuedx/typescript-plugin-vue": "0.7.6",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.5.0",
    "jest": "30.3.0",
    "jest-serializer-vue": "3.1.0",
    "jest-transform-stub": "2.0.0",
    "postcss-html": "1.8.1",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "stylelint": "17.8.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-scss": "7.0.0",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.9",
    "vite-plugin-vue-devtools": "8.1.1",
    "vue-eslint-parser": "10.4.0",
    "vue-jest": "3.0.7",
    "vue-tsc": "3.2.7"
  },
  "packageManager": "pnpm@10.32.1"
}
